<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
    <properties resource="generator.properties"/>
    <context id="MySqlContext" targetRuntime="MyBatis3" defaultModelType="flat">
        <!-- SQL 标识符前置分隔符（MySQL 用反引号） -->
        <property name="beginningDelimiter" value="`"/>
        <!-- SQL 标识符后置分隔符 -->
        <property name="endingDelimiter" value="`"/>
        <!-- 生成 Java 源文件编码 -->
        <property name="javaFileEncoding" value="UTF-8"/>
        <!-- 为实体类实现 Serializable -->
        <plugin type="org.mybatis.generator.plugins.SerializablePlugin"/>
        <!-- 为实体类生成 toString -->
        <plugin type="org.mybatis.generator.plugins.ToStringPlugin"/>
        <!-- 生成 mapper.xml 时覆盖已有文件 -->
        <plugin type="org.mybatis.generator.plugins.UnmergeableXmlMappersPlugin" />
        <commentGenerator type="com.project.mall.CommentGenerator">
            <!-- 不生成默认注释块 -->
            <property name="suppressAllComments" value="true"/>
            <!-- 注释中不包含时间戳 -->
            <property name="suppressDate" value="true"/>
            <!-- 使用列备注生成 OpenAPI @Schema（见 CommentGenerator） -->
            <property name="addRemarkComments" value="true"/>
        </commentGenerator>
        <!-- JDBC 连接（账号见 generator.properties，勿提交真实密码到仓库） -->
        <jdbcConnection driverClass="${jdbc.driverClass}"
                        connectionURL="${jdbc.connectionURL}"
                        userId="${jdbc.userId}"
                        password="${jdbc.password}">
            <!-- 避免 MySQL 8+ 下生成到错误 catalog -->
            <property name="nullCatalogMeansCurrent" value="true" />
        </jdbcConnection>
        <!-- 实体类输出目录（使用 / 以便在 Windows/Linux 下一致） -->
        <javaModelGenerator targetPackage="com.project.mall.model" targetProject="mall-mbg/src/main/java"/>
        <!-- Mapper XML 输出目录 -->
        <sqlMapGenerator targetPackage="com.project.mall.mapper" targetProject="mall-mbg/src/main/resources"/>
        <!-- Mapper 接口输出目录 -->
        <javaClientGenerator type="XMLMAPPER" targetPackage="com.project.mall.mapper"
                             targetProject="mall-mbg/src/main/java"/>
        <!-- tableName=% 表示当前库全部表 -->
        <table tableName="%">
            <!-- 主键自增 -->
            <generatedKey column="id" sqlStatement="MySql" identity="true"/>
        </table>
    </context>
</generatorConfiguration>
